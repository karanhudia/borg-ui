{
  "name": "borg-web-ui-frontend",
  "version": "2.2.3",
  "type": "module",
  "description": "React frontend for Borg Web UI",
  "license": "AGPL-3.0",
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@eslint/js": "^9.39.1",
    "@monaco-editor/react": "^4.7.0",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.5",
    "@tanstack/react-query": "^5.101.2",
    "@types/node": "^26.1.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "axios": "^1.18.1",
    "clsx": "^2.0.0",
    "cron-parser": "^5.6.1",
    "date-fns": "^4.4.0",
    "i18next": "^26.3.6",
    "lucide-react": "^1.24.0",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.81.0",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^17.0.9",
    "react-icons": "^5.7.0",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/react-vite": "^10.5.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.48.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.5.2",
    "axios-mock-adapter": "^2.1.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "playwright": "^1.61.1",
    "pngjs": "^7.0.0",
    "postcss": "^8.5.17",
    "prettier": "^3.9.5",
    "storybook": "^10.4.0",
    "tailwindcss": "^3.4.18",
    "typescript": "^6.0.3",
    "vite": "^7.3.2",
    "vitest": "^4.0.18"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static",
    "snapshots": "npm run visual:screenshots",
    "visual:screenshots": "npm run build-storybook && node scripts/generate-storybook-snapshots.mjs",
    "visual:report": "node scripts/visual-regression-report.mjs",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "check:locales": "node ../scripts/check-locale-parity.js",
    "release": "cd .. && ./scripts/release.sh",
    "start:dev": "cd .. && ./scripts/dev.sh",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx,json,css,md}": [
      "prettier --write"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "overrides": {
    "dompurify": "3.4.11"
  }
}
